  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background-color: #0b0f14;
    color: #e6e6e6;
    font-family: &quot;Segoe UI&quot;;
}

/* Базовый текст */
QLabel {
    background: transparent;
    border: none;
}

/* ===== SIDEBAR ===== */
#sidebarFrame {
    background-color: #11161d;
    border-radius: 14px;
}

#sidebarFrame QPushButton {
    background: transparent;
    border: none;
    text-align: left;
    padding: 10px 12px;
    border-radius: 10px;
    color: #c9d1d9;
    font-size: 10pt;
}

#sidebarFrame QPushButton:hover {
    background-color: #1b2129;
}

#sidebarFrame QPushButton:checked {
    background-color: #d32f2f;
    color: white;
}

/* Нижняя кнопка */
#sidebarFrame QPushButton#bottomAddGameButton {
    background-color: #942B2B;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px;
}

#sidebarFrame QPushButton#bottomAddGameButton:hover {
    background-color: #b33636;
}

#sidebarFrame QPushButton#bottomAddGameButton:pressed {
    background-color: #7a2323;
}

/* ===== HEADER / FILTERS ===== */
QLineEdit, QComboBox {
    background-color: #141a22;
    border: 1px solid #2c3440;
    border-radius: 10px;
    padding: 6px;
    color: #e6e6e6;
}

QComboBox::drop-down {
    border: none;
    width: 18px;
}

QComboBox::down-arrow {
    image: none;
    border: none;
}

/* ===== BUTTONS ===== */
QPushButton {
    background-color: #1c222b;
    border: none;
    border-radius: 10px;
    padding: 6px 12px;
    color: white;
}

QPushButton:hover {
    background-color: #2a313d;
}

QPushButton#addGameButton {
    background-color: #d32f2f;
    color: white;
    font-weight: bold;
}

QPushButton#addGameButton:hover {
    background-color: #ff3d3d;
}

QPushButton#viewAchievementsButton {
    background-color: #1c222b;
    border-radius: 8px;
    padding: 8px;
    color: white;
}

QPushButton#viewAchievementsButton:hover {
    background-color: #2a313d;
}

/* ===== LISTS ===== */
QListWidget {
    border: none;
    background: transparent;
    outline: none;
}

QListWidget::item {
    background-color: #141a22;
    border: 1px solid transparent;
    border-radius: 12px;
    padding: 10px 16px;
    margin: 6px 0px;
    color: #e6e6e6;
    font-family: &quot;Consolas&quot;;
}

QListWidget::item:selected {
    background-color: #141a22;
    border: 2px solid #ff3d3d;
    outline: none;
}

QListWidget::item:hover {
    background-color: #171f29;
}

/* Список останніх досягнень */
QListWidget#recentAchievementsList {
    background: transparent;
    border: none;
    padding-right: 12px;
    outline: none;
}

QListWidget#recentAchievementsList::item {
    background-color: #141a22;
    border: 1px solid transparent;
    border-radius: 10px;
    padding: 10px;
    margin: 0px 10px 8px 0px;
    color: #e6e6e6;
    font-family: &quot;Segoe UI&quot;;
}

QListWidget#recentAchievementsList::item:selected {
    background-color: #1a2230;
    border: 1px solid #2a313d;
}

/* ===== DETAILS PANEL ===== */
#detailsFrame {
    background-color: #11161d;
    border-radius: 14px;
}

#detailsFrame QLabel {
    background: transparent;
    border: none;
}

#coverLabel {
    background-color: #0a0f14;
    border-radius: 10px;
    font-size: 14pt;
    font-weight: bold;
    color: #d7c58a;
}

#gameNameLabel {
    font-size: 16pt;
    font-weight: bold;
    color: white;
}

/* ===== PROGRESS ===== */
QProgressBar {
    background-color: #2a313d;
    border: none;
    border-radius: 6px;
    text-align: center;
    color: white;
}

QProgressBar::chunk {
    background-color: #ff3d3d;
    border-radius: 6px;
}

/* ===== SCROLLBAR ===== */
QScrollBar:vertical {
    background: transparent;
    width: 6px;
    margin: 8px 2px 8px 0px;
    border-radius: 3px;
}

QScrollBar::handle:vertical {
    background: #2a313d;
    border-radius: 3px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #3a4352;
}

QScrollBar::handle:vertical:pressed {
    background: #ff3d3d;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}</string>
