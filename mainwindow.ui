         <string notr="true">#settingsFrame {
    background-color: #11161d;
    border-radius: 14px;
}

#settingsFrame QLabel#settingsTitleLabel {
    font-size: 18pt;
    font-weight: 800;
    color: white;
}

#settingsFrame QLabel.sectionLabel {
    color: #9aa4b2;
    font-size: 11pt;
    font-weight: 700;
}

#settingsFrame QPushButton.optionButton {
    background-color: #141a22;
    border: 1px solid #2c3440;
    border-radius: 10px;
    padding: 10px 12px;
    text-align: left;
    font-weight: 700;
}

#settingsFrame QPushButton.optionButton:checked {
    border: 1px solid #d32f2f;
}</string>
