  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background-color: #0d1117;
    color: #f2f2f2;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
}

#centralwidget {
    background-color: #0d1117;
}

QFrame#sidebarFrame {
    background-color: #131720;
    border-radius: 14px;
}

QFrame#detailsFrame {
    background-color: #131720;
    border-radius: 14px;
}

QFrame#topBarFrame {
    background-color: transparent;
}

QLabel#logoLabel {
    font-size: 16pt;
    font-weight: 700;
    color: white;
}

QLabel#sectionTitleLabel {
    font-size: 18pt;
    font-weight: 700;
    color: white;
}

QLabel#gamesCountLabel {
    color: #7d8590;
    font-size: 9pt;
}

QPushButton {
    background-color: #1c212b;
    border: none;
    border-radius: 8px;
    padding: 8px 12px;
    color: white;
}

QPushButton:hover {
    background-color: #262c36;
}

QPushButton#libraryButton {
    background-color: #b3261e;
    font-weight: 600;
}

QPushButton#libraryButton:hover {
    background-color: #cf2f25;
}

QPushButton#addGameButton {
    background-color: #c62828;
    font-weight: 700;
}

QPushButton#addGameButton:hover {
    background-color: #e53935;
}

QPushButton#viewAchievementsButton {
    background-color: #b3261e;
    font-weight: 600;
}

QPushButton#viewAchievementsButton:hover {
    background-color: #cf2f25;
}

QLineEdit, QComboBox {
    background-color: #1a1f29;
    border: 1px solid #2c3440;
    border-radius: 8px;
    padding: 7px 8px;
    color: white;
}

QComboBox::drop-down {
    border: none;
    width: 18px;
}

QListWidget#gamesList {
    background-color: transparent;
    border: none;
    outline: none;
}

QListWidget#gamesList::item {
    background-color: #171c25;
    border: 1px solid #171c25;
    border-radius: 12px;
    margin: 6px 0px;
    padding: 14px;
}

QListWidget#gamesList::item:selected {
    border: 1px solid #c62828;
    background-color: #171c25;
}

QListWidget#recentAchievementsList {
    background-color: #171c25;
    border: none;
    border-radius: 10px;
    padding: 6px;
}

QProgressBar {
    background-color: #2a313d;
    border: none;
    border-radius: 6px;
    text-align: center;
    color: white;
}

QProgressBar::chunk {
    background-color: #e53935;
    border-radius: 6px;
}

QLabel#detailsHeaderLabel {
    font-size: 16pt;
    font-weight: 700;
}

QLabel#gameNameLabel {
    font-size: 20pt;
    font-weight: 700;
}

QLabel#mutedLabel, QLabel#genreInfoLabel, QLabel#hoursInfoLabel,
QLabel#totalAchievementsInfoLabel, QLabel#openedAchievementsInfoLabel,
QLabel#platformInfoLabel {
    color: #a7b0bb;
}

QFrame#coverFrame {
    background-color: #0f131a;
    border-radius: 10px;
}

QLabel#coverLabel {
    font-size: 18pt;
    font-weight: 700;
    color: #e7d7a5;
    background-color: #0b0f14;
    border-radius: 8px;
}

QScrollBar:vertical {
    border: none;
    background: #0d1117;
    width: 10px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #2a313d;
    min-height: 24px;
    border-radius: 5px;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}</string>
