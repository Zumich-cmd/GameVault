  <property name="windowTitle">
   <string>GameVault</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background-color: #0b0f14;
    color: #e6e6e6;
}

/* Базовый текст */
QLabel {
    background: transparent;
    border: none;
}

/* ===== SIDEBAR ===== */
#sidebarFrame {
    background-color: #11161d;
    border-radius: 14px;
}

#sidebarFrame QPushButton {
    background: transparent;
    border: none;
    text-align: left;
    padding: 10px 12px;
    border-radius: 10px;
    color: #c9d1d9;
    font-size: 10pt;
}

#sidebarFrame QPushButton:hover {
    background-color: #252d39;
}

#sidebarFrame QPushButton:pressed {
    background-color: #1b222d;
}

#sidebarFrame QPushButton:checked {
    background-color: #d32f2f;
    color: white;
}

/* Нижняя кнопка */
#sidebarFrame QPushButton#bottomAddGameButton {
    background-color: #942B2B;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px;
}

#sidebarFrame QPushButton#bottomAddGameButton:hover {
    background-color: #b33636;
}

#sidebarFrame QPushButton#bottomAddGameButton:pressed {
    background-color: #7a2323;
}

/* ===== HEADER / FILTERS ===== */
QLineEdit, QComboBox {
    background-color: #141a22;
    border: 1px solid #2c3440;
    border-radius: 10px;
    padding: 6px;
    color: #e6e6e6;
}

QComboBox::drop-down {
    border: none;
    width: 18px;
}

QComboBox::down-arrow {
    image: none;
    border: none;
}

/* ===== BUTTONS ===== */
QPushButton {
    background-color: #1c222b;
    border: none;
    border-radius: 10px;
    padding: 6px 12px;
    color: white;
}

QPushButton:hover {
    background-color: #323b49;
}

QPushButton:pressed {
    background-color: #262d38;
}

QPushButton#addGameButton {
    background-color: #d32f2f;
    color: white;
    font-weight: bold;
}

QPushButton#addGameButton:hover {
    background-color: #ff3d3d;
}

QPushButton#viewAchievementsButton {
    background-color: #9f2727;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 11pt;
    font-weight: 800;
    color: white;
}

QPushButton#viewAchievementsButton:hover {
    background-color: #c13333;
}

QPushButton#viewAchievementsButton:pressed {
    background-color: #7e1f1f;
}

/* ===== LISTS ===== */
QListWidget {
    border: none;
    background: transparent;
    outline: none;
}

QListWidget::item {
    background-color: #141a22;
    border: 1px solid transparent;
    border-radius: 12px;
    padding: 10px 16px;
    margin: 6px 0px;
    color: #e6e6e6;
    font-family: &quot;Consolas&quot;;
}

QListWidget::item:selected {
    background-color: #141a22;
    border: 2px solid #ff3d3d;
    outline: none;
}

QListWidget::item:hover {
    background-color: #171f29;
}

/* Список останніх досягнень */
QListWidget#recentAchievementsList {
    background: transparent;
    border: none;
    padding-right: 12px;
    outline: none;
}

QListWidget#recentAchievementsList::item {
    background: transparent;
    border: none;
    border-radius: 0px;
    padding: 0px;
    margin: 0px 0px 2px 0px;
    color: #e6e6e6;
    font-family: &quot;Segoe UI&quot;;
}

QListWidget#recentAchievementsList::item:selected {
    background: transparent;
    border: none;
}

QListWidget#recentAchievementsList QScrollBar:vertical {
    background: #0f141c;
    width: 6px;
    margin: 6px 2px 6px 0px;
    border-radius: 3px;
}

QListWidget#recentAchievementsList QScrollBar::handle:vertical {
    background: #344053;
    border-radius: 3px;
    min-height: 28px;
}

QListWidget#recentAchievementsList QScrollBar::handle:vertical:hover {
    background: #46556b;
}

QListWidget#recentAchievementsList QScrollBar::handle:vertical:pressed {
    background: #ff3d3d;
}

QListWidget#recentAchievementsList QScrollBar::add-line:vertical,
QListWidget#recentAchievementsList QScrollBar::sub-line:vertical {
    height: 0px;
}

QListWidget#recentAchievementsList QScrollBar::add-page:vertical,
QListWidget#recentAchievementsList QScrollBar::sub-page:vertical {
    background: transparent;
}

/* ===== DETAILS PANEL ===== */
#detailsFrame {
    background-color: #11161d;
    border-radius: 14px;
}

#detailsFrame QLabel {
    background: transparent;
    border: none;
}

#coverFrame {
    background: transparent;
}

#coverLabel {
    background-color: #0a0f14;
    border-radius: 12px;
    padding: 0px;
    font-size: 18pt;
    font-weight: bold;
    color: #d7c58a;
}

#gameNameLabel {
    font-size: 18pt;
    font-weight: bold;
    color: white;
}

#genreInfoLabel {
    color: #7f8b9a;
    font-size: 14px;
    font-weight: 600;
}

#hoursInfoLabel,
#totalAchievementsInfoLabel,
#openedAchievementsInfoLabel {
    color: #f2f4f8;
    font-size: 12px;
    font-weight: 700;
}

#mutedLabel {
    color: #ffffff;
    font-size: 14px;
    font-weight: 800;
}

#platformInfoLabel {
    color: #9aa4b2;
    font-size: 12px;
    font-weight: 700;
}

/* ===== PROGRESS ===== */
QProgressBar {
    background-color: #2a313d;
    border: none;
    border-radius: 6px;
    text-align: center;
    color: white;
}

QProgressBar::chunk {
    background-color: #ff3d3d;
    border-radius: 6px;
}

/* ===== SCROLLBAR ===== */
QScrollBar:vertical {
    background: transparent;
    width: 6px;
    margin: 8px 2px 8px 0px;
    border-radius: 3px;
}

QScrollBar::handle:vertical {
    background: #2a313d;
    border-radius: 3px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #3a4352;
}

QScrollBar::handle:vertical:pressed {
    background: #ff3d3d;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}

QListWidget#gamesList QScrollBar:vertical {
    background: #0f141c;
    width: 8px;
    margin: 6px 2px 6px 0px;
    border-radius: 4px;
}

QListWidget#gamesList QScrollBar::handle:vertical {
    background: #3a4352;
    border-radius: 4px;
    min-height: 40px;
}

QListWidget#gamesList QScrollBar::handle:vertical:hover {
    background: #4a5668;
}

QListWidget#gamesList QScrollBar::handle:vertical:pressed {
    background: #ff3d3d;
}

QListWidget#gamesList QScrollBar::add-line:vertical,
QListWidget#gamesList QScrollBar::sub-line:vertical {
    height: 0px;
}

QListWidget#gamesList QScrollBar::add-page:vertical,
QListWidget#gamesList QScrollBar::sub-page:vertical {
    background: transparent;
}

QListWidget#gamesList QScrollBar:horizontal {
    height: 0px;
}

QListWidget#gamesList::item:selected {
    background: transparent;
    border: none;
}

QListWidget#gamesList::item {
    padding: 0px;
    margin: 6px 0px;
    background: transparent;
    border: none;
}

QListWidget#gamesList::item:hover {
    background: transparent;
}</string>
